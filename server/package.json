{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "node-pg-migrate",
    "db:create": "node-pg-migrate create --migrations-dir src/db-migrations --migration-file-language ts",
    "db:up": "node-pg-migrate up --migrations-dir src/db-migrations --migration-file-language ts",
    "db:down": "node-pg-migrate down --migrations-dir src/db-migrations --migration-file-language ts",
    "db:seed": "tsx src/db/seeds/products.seed.ts",
    "server:test:unit": "NODE_OPTIONS=--experimental-vm-modules jest",
    "server:test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "prepare": "cp ../.githooks/pre-commit ../.git/hooks/pre-commit && chmod +x ../.git/hooks/pre-commit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pg": "^8.20.0",
    "jest": "^29.7.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.4",
    "ts-jest": "^29.2.5",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  }
}

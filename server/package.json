{
  "name": "server",
  "version": "1.0.0",
  "description": "",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "migrate": "node-pg-migrate",
    "db:create": "node-pg-migrate create --migrations-dir src/db-migrations --migration-file-language ts",
    "db:up": "node-pg-migrate up --migrations-dir src/db-migrations --migration-file-language ts",
    "db:down": "node-pg-migrate down --migrations-dir src/db-migrations",
    "db:seed": "tsx src/db/seeds/products.seed.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\"",
    "prepare": "cp ../.githooks/pre-commit ../.git/hooks/pre-commit && chmod +x ../.git/hooks/pre-commit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.21.0"
  }
}
